{
  "kind": "collectionType",
  "collectionName": "navigation_menus",
  "info": {
    "singularName": "navigation-menu",
    "pluralName": "navigation-menus",
    "displayName": "Navigation Menu",
    "description": "Dynamic website menus supporting nested children and multi-language links"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "location": {
      "type": "enumeration",
      "enum": ["header", "footer", "topbar"],
      "default": "header"
    },
    "items": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.menu-item"
    }
  }
}
