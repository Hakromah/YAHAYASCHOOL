{
  "kind": "collectionType",
  "collectionName": "dawah_activities",
  "info": {
    "singularName": "dawah-activity",
    "pluralName": "dawah-activities",
    "displayName": "Dawah Activity",
    "description": "Schema for Dawah Activity"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "location": {
      "type": "string"
    },
    "date": {
      "type": "date",
      "required": true
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "videos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "videos"
      ]
    },
    "teacher": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::teacher.teacher"
    },
    "students": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::student.student"
    }
  }
}