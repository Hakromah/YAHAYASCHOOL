{
  "kind": "collectionType",
  "collectionName": "finance_payrolls",
  "info": {
    "singularName": "finance-payroll",
    "pluralName": "finance-payrolls",
    "displayName": "Finance Payroll",
    "description": "Staff Payroll Runs and Compensation Vouchers"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "payrollNumber": {
      "type": "string"
    },
    "payPeriod": {
      "type": "string"
    },
    "staffId": {
      "type": "string"
    },
    "staffName": {
      "type": "string"
    },
    "staffRole": {
      "type": "string"
    },
    "department": {
      "type": "string"
    },
    "baseSalary": {
      "type": "decimal",
      "default": 0
    },
    "overtimeHours": {
      "type": "integer",
      "default": 0
    },
    "overtimeAmount": {
      "type": "decimal",
      "default": 0
    },
    "deductionsAmount": {
      "type": "decimal",
      "default": 0
    },
    "netPayable": {
      "type": "decimal",
      "default": 0
    },
    "attendanceRate": {
      "type": "decimal",
      "default": 100
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "draft",
        "submitted",
        "reviewed",
        "approved",
        "paid",
        "closed"
      ],
      "default": "draft"
    },
    "journalEntryId": {
      "type": "string"
    }
  }
}
