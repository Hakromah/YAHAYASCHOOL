{
  "kind": "collectionType",
  "collectionName": "audit_logs",
  "info": {
    "singularName": "audit-log",
    "pluralName": "audit-logs",
    "displayName": "Audit Log",
    "description": "System audit trail for all important administrative and financial actions"
  },
  "options": {
    "draftAndPublish": false,
    "comment": ""
  },
  "pluginOptions": {},
  "attributes": {
    "action": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "entity": {
      "type": "string",
      "maxLength": 100
    },
    "entityId": {
      "type": "string",
      "maxLength": 100
    },
    "description": {
      "type": "text"
    },
    "metadata": {
      "type": "json"
    },
    "ipAddress": {
      "type": "string",
      "maxLength": 45
    },
    "userAgent": {
      "type": "text"
    },
    "severity": {
      "type": "enumeration",
      "enum": ["info", "warning", "error", "critical"],
      "default": "info"
    },
    "performedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
