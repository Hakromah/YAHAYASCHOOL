{
  "kind": "singleType",
  "collectionName": "contact_infos",
  "info": {
    "singularName": "contact-info",
    "pluralName": "contact-infos",
    "displayName": "Contact Information",
    "description": "School contact details, office hours, and maps"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "address": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "text",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "officeHours": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "default": "Mon - Fri: 8:00 AM - 4:00 PM"
    },
    "googleMapUrl": {
      "type": "string"
    },
    "emergencyContacts": {
      "type": "json"
    },
    "socialMedia": {
      "type": "json"
    }
  }
}
