{
  "kind": "collectionType",
  "collectionName": "teachers",
  "info": {
    "singularName": "teacher",
    "pluralName": "teachers",
    "displayName": "Teacher Management",
    "description": "Faculty, Sheikhs, and teaching staff profiles"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "schoolId": {
      "type": "string",
      "required": false,
      "unique": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "name": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "male",
        "female"
      ]
    },
    "qualifications": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string"
    },
    "specializations": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string"
    },
    "experienceYears": {
      "type": "integer",
      "default": 5
    },
    "subjects": {
      "type": "json"
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email"
    },
    "address": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "text"
    },
    "employmentDate": {
      "type": "date"
    },
    "employmentStatus": {
      "type": "enumeration",
      "enum": [
        "active",
        "on_leave",
        "retired",
        "suspended",
        "contract",
        "part_time",
        "full_time"
      ],
      "default": "active"
    },
    "salaryGrade": {
      "type": "string"
    },
    "biography": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "richtext"
    },
    "emergencyContact": {
      "type": "string"
    },
    "documents": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "files",
        "images"
      ]
    },
    "departments": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::department.department",
      "mappedBy": "teachersList"
    },
    "programs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::program.program",
      "mappedBy": "teachersList"
    },
    "sections": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::section.section",
      "mappedBy": "teachers"
    },
    "students": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::student.student",
      "inversedBy": "teachers"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
