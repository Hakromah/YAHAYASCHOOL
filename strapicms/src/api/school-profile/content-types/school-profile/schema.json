{
  "kind": "singleType",
  "collectionName": "school_profiles",
  "info": {
    "singularName": "school-profile",
    "pluralName": "school-profiles",
    "displayName": "School Profile",
    "description": "Global school settings, branding, and configuration"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "schoolName": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true,
      "maxLength": 200,
      "default": "Yahaya International Islamic and English High School"
    },
    "motto": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "text"
    },
    "address": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "text"
    },
    "phone": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "string",
      "maxLength": 30
    },
    "email": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "email"
    },
    "website": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "string",
      "maxLength": 200
    },
    "logo": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "academicYearStart": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "date"
    },
    "academicYearEnd": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "date"
    },
    "timezone": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "string",
      "default": "Africa/Lagos",
      "maxLength": 100
    },
    "defaultLanguage": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "enumeration",
      "enum": ["en", "ar", "fr", "tr"],
      "default": "en"
    },
    "socialLinks": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "json"
    },
    "registrationNumber": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "string",
      "maxLength": 100
    },
    "foundedYear": {
      "pluginOptions": { "i18n": { "localized": false } },
      "type": "integer",
      "min": 1900,
      "max": 2100
    }
  }
}
