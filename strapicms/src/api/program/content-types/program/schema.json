{
  "kind": "collectionType",
  "collectionName": "programs",
  "info": {
    "singularName": "program",
    "pluralName": "programs",
    "displayName": "Program",
    "description": "Academic and specialized programs (e.g. Qur'an Memorization, Sciences, Languages)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "slug": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "code": {
      "type": "string"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "description": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "text",
      "required": true
    },
    "objectives": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "richtext"
    },
    "duration": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "default": "Full Academic Year"
    },
    "requirements": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "richtext"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "downloads": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["files"]
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "department": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::department.department",
      "inversedBy": "programs"
    },
    "sectionsList": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::section.section",
      "mappedBy": "program"
    },
    "studentsList": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::student.student",
      "inversedBy": "programs"
    },
    "teachersList": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::teacher.teacher",
      "inversedBy": "programs"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.meta"
    }
  }
}
