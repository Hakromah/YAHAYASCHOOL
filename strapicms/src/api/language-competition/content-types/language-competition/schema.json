{
  "kind": "collectionType",
  "collectionName": "language_competitions",
  "info": {
    "singularName": "language-competition",
    "pluralName": "language-competitions",
    "displayName": "Language Competition",
    "description": "Schema for Language Competition"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Debate",
        "Speech Contest",
        "Essay Competition",
        "Reading Competition",
        "Spelling Bee",
        "Poetry Recitation",
        "Translation",
        "Storytelling"
      ]
    },
    "date": {
      "type": "date"
    },
    "judges": {
      "type": "string"
    },
    "ranking": {
      "type": "integer"
    },
    "awards": {
      "type": "string"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "students": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::student.student"
    }
  }
}