{
  "kind": "collectionType",
  "collectionName": "academic_years",
  "info": {
    "singularName": "academic-year",
    "pluralName": "academic-years",
    "displayName": "Academic Year",
    "description": "School academic calendar year with terms and enrollments"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "type": "string",
      "required": true
    },
    "startDate": {
      "type": "date",
      "required": true
    },
    "endDate": {
      "type": "date",
      "required": true
    },
    "recordStatus": {
      "type": "enumeration",
      "enum": [
        "planned",
        "active",
        "completed"
      ],
      "default": "active",
      "required": true
    },
    "isCurrent": {
      "type": "boolean",
      "default": true
    },
    "terms": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::academic-term.academic-term",
      "mappedBy": "academicYear"
    },
    "students": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::student.student",
      "inversedBy": "academicYears"
    },
    "sections": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::section.section",
      "mappedBy": "academicYear"
    },
    "departments": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::department.department"
    }
  }
}
