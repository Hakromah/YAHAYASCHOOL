{
  "kind": "collectionType",
  "collectionName": "workers",
  "info": {
    "singularName": "worker",
    "pluralName": "workers",
    "displayName": "Worker Management",
    "description": "Support staff profiles (Security, Cleaners, Cooks, Drivers, ICT, Mosque Caretakers)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "schoolId": {
      "type": "string",
      "required": false,
      "unique": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "name": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "role": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "employmentDate": {
      "type": "date"
    },
    "employmentStatus": {
      "type": "enumeration",
      "enum": [
        "active",
        "on_leave",
        "retired",
        "suspended",
        "contract",
        "part_time",
        "full_time"
      ],
      "default": "active"
    },
    "salaryGrade": {
      "type": "string"
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email"
    },
    "address": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "text"
    },
    "emergencyContact": {
      "type": "string"
    },
    "documents": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "files",
        "images"
      ]
    },
    "departments": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::department.department",
      "mappedBy": "workersList"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
