{
  "kind": "collectionType",
  "collectionName": "partners",
  "info": {
    "singularName": "partner",
    "pluralName": "partners",
    "displayName": "Partner & Sponsor",
    "description": "School accreditation bodies, educational partners, and waqf sponsors"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "websiteUrl": {
      "type": "string"
    },
    "partnerType": {
      "type": "enumeration",
      "enum": ["accreditation", "educational", "waqf_sponsor", "partner"],
      "default": "educational"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
