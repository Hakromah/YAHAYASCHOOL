{
  "kind": "collectionType",
  "collectionName": "departments",
  "info": {
    "singularName": "department",
    "pluralName": "departments",
    "displayName": "Department",
    "description": "Academic and administrative faculties/departments"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "slug": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "code": {
      "type": "string"
    },
    "color": {
      "type": "string",
      "default": "#10B981"
    },
    "icon": {
      "type": "string",
      "default": "book-open"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "description": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "richtext"
    },
    "headOfDepartment": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images", "videos"]
    },
    "teachers": {
      "type": "json"
    },
    "announcements": {
      "type": "json"
    },
    "programs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::program.program",
      "mappedBy": "department"
    },
    "sectionsList": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::section.section",
      "mappedBy": "department"
    },
    "teachersList": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::teacher.teacher",
      "inversedBy": "departments"
    },
    "studentsList": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::student.student",
      "inversedBy": "departments"
    },
    "workersList": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::worker.worker",
      "inversedBy": "departments"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "seo.meta"
    }
  }
}
