{
  "kind": "collectionType",
  "collectionName": "faqs",
  "info": {
    "singularName": "faq",
    "pluralName": "faqs",
    "displayName": "FAQ",
    "description": "Frequently asked questions categorized by topic"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "question": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "answer": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "richtext",
      "required": true
    },
    "category": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "default": "Admissions"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
