{
  "collectionName": "components_erp_timeline_items",
  "info": {
    "displayName": "Timeline Item",
    "icon": "clock",
    "description": "Chronological milestone entries for student ERP timeline"
  },
  "options": {},
  "attributes": {
    "date": {
      "type": "date",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Admission",
        "Department Change",
        "Section Change",
        "Parent Update",
        "Hostel Assignment",
        "Behavior Record",
        "Certificate",
        "Exam",
        "Attendance Milestone",
        "Transfer",
        "Graduation"
      ],
      "default": "Admission",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "loggedBy": {
      "type": "string"
    }
  }
}
